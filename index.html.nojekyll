                    ]
                },
                hospital: {
                    background: '#d5eafc',
                    items: [
                        { iconType: 'doctor', x: 120, y: 200 },
                        { iconType: 'nurse', x: 220, y: 200 },
                        { iconType: 'pill', x: 320, y: 200 },
                        { iconType: 'bandage', x: 420, y: 200 },
                        { iconType: 'syringe', x: 170, y: 300 },
                        { iconType: 'heart', x: 270, y: 300 },
                        { iconType: 'thermometer', x: 370, y: 300 },
                        { iconType: 'bed_hosp', x: 470, y: 300 },
                    ]
                },
                school: {
                    background: '#fef8d0',
                    items: [
                        { iconType: 'book', x: 100, y: 200 },
                        { iconType: 'pen', x: 200, y: 200 },
                        { iconType: 'pencil', x: 300, y: 200 },
                        { iconType: 'ruler', x: 400, y: 200 },
                        { iconType: 'eraser', x: 150, y: 300 },
                        { iconType: 'bag', x: 250, y: 300 },
                        { iconType: 'desk', x: 350, y: 300 },
                        { iconType: 'globe', x: 450, y: 300 },
                    ]
                },
                park: {
                    background: '#d8f0d0',
                    items: [
                        { iconType: 'tree', x: 80, y: 200 },
                        { iconType: 'flower', x: 180, y: 200 },
                        { iconType: 'bird', x: 280, y: 180 },
                        { iconType: 'kite', x: 380, y: 150 },
                        { iconType: 'ball', x: 200, y: 300 },
                        { iconType: 'swing', x: 320, y: 300 },
                        { iconType: 'bench', x: 420, y: 300 },
                        { iconType: 'butterfly', x: 480, y: 220 },
                    ]
                },
                home: {
                    background: '#fce4ec',
                    items: [
                        { iconType: 'bed_home', x: 120, y: 200 },
                        { iconType: 'table', x: 240, y: 220 },
                        { iconType: 'chair', x: 350, y: 230 },
                        { iconType: 'lamp', x: 450, y: 180 },
                        { iconType: 'clock', x: 180, y: 300 },
                        { iconType: 'door', x: 300, y: 280 },
                        { iconType: 'sofa', x: 400, y: 300 },
                        { iconType: 'phone', x: 480, y: 300 },
                    ]
                }
            };

            // ==================== 探索模式绘制 ====================
            function drawExploreScene() {
                const scene = getCurrentScene();
                const layout = sceneLayouts[scene.id];
                if (!layout) return;

                const canvas = exploreCanvas;
                const ctx = canvas.getContext('2d');
                const w = canvas.width,
                    h = canvas.height;

                // 背景
                ctx.fillStyle = layout.background;
                ctx.fillRect(0, 0, w, h);

                // 场景装饰
                if (scene.id === 'supermarket') {
                    ctx.fillStyle = '#d2a679';
                    ctx.fillRect(0, h - 60, w, 60);
                    ctx.fillStyle = '#b88a5c';
                    for (let i = 0; i < 6; i++) ctx.fillRect(100 * i, h - 60, 5, 60);
                } else if (scene.id === 'hospital') {
                    ctx.fillStyle = '#e8e8e8';
                    ctx.fillRect(0, h - 50, w, 50);
                    ctx.fillStyle = '#4d8ecb';
                    ctx.fillRect(20, h - 80, 80, 30);
                } else if (scene.id === 'school') {
                    ctx.fillStyle = '#a0d8a0';
                    ctx.fillRect(0, h - 40, w, 40);
                    ctx.fillStyle = '#8b6e5e';
                    ctx.fillRect(100, h - 100, 150, 60);
                } else if (scene.id === 'park') {
                    ctx.fillStyle = '#8bc34a';
                    ctx.fillRect(0, h - 30, w, 30);
                } else if (scene.id === 'home') {
                    ctx.fillStyle = '#e0c8a0';
                    ctx.fillRect(0, h - 40, w, 40);
                }

                // 绘制物品
                layout.items.forEach(item => {
                    const word = scene.words.find(w => w.iconType === item.iconType);
                    if (!word) return;

                    const tempCanvas = document.createElement('canvas');
                    tempCanvas.width = 64;
                    tempCanvas.height = 64;
                    drawPixelIcon(tempCanvas, item.iconType, word.iconColor);
                    ctx.drawImage(tempCanvas, item.x - 32, item.y - 32, 64, 64);

                    // 物品小标签
                    ctx.fillStyle = '#ffffffcc';
                    ctx.fillRect(item.x - 25, item.y + 18, 50, 14);
                    ctx.fillStyle = '#3d2b1f';
                    ctx.font = '8px "Press Start 2P"';
                    ctx.fillText(word.en, item.x - 24, item.y + 29);
                });

                // 绘制主角
                drawPlayer(ctx, w / 2, h - 50);

                exploreSceneTitle.textContent = scene.emoji + ' ' + scene.name;
            }

            function drawPlayer(ctx, x, y) {
                ctx.fillStyle = '#f5d5b8';
                ctx.fillRect(x - 6, y - 14, 12, 10);
                ctx.fillStyle = '#3d2b1f';
                ctx.fillRect(x - 3, y - 12, 3, 3);
                ctx.fillRect(x + 1, y - 12, 3, 3);
                ctx.fillStyle = '#e8536c';
                ctx.fillRect(x - 8, y - 4, 16, 14);
                ctx.fillStyle = '#4d8ecb';
                ctx.fillRect(x - 6, y + 10, 12, 10);
                ctx.fillStyle = '#8b5e3c';
                ctx.fillRect(x - 8, y + 20, 7, 4);
                ctx.fillRect(x + 1, y + 20, 7, 4);
                ctx.fillStyle = '#f0b440';
                ctx.fillRect(x - 7, y - 18, 14, 5);
                ctx.fillRect(x - 5, y - 22, 10, 5);
            }

            function handleCanvasClick(e) {
                const rect = exploreCanvas.getBoundingClientRect();
                const scaleX = exploreCanvas.width / rect.width;
                const scaleY = exploreCanvas.height / rect.height;

                const mouseX = (e.clientX - rect.left) * scaleX;
                const mouseY = (e.clientY - rect.top) * scaleY;

                const scene = getCurrentScene();
                const layout = sceneLayouts[scene.id];
                if (!layout) return;

                for (let item of layout.items) {
                    if (mouseX >= item.x - 32 && mouseX <= item.x + 32 &&
                        mouseY >= item.y - 32 && mouseY <= item.y + 32) {
                        const word = scene.words.find(w => w.iconType === item.iconType);
                        if (word) {
                            showWordPopup(word.en, e.clientX, e.clientY);
                            speakWord(word.en);
                        }
                        return;
                    }
                }
                wordPopup.classList.add('hidden');
            }

            function showWordPopup(word, cx, cy) {
                popupWord.textContent = word;
                wordPopup.style.left = cx + 'px';
                wordPopup.style.top = (cy - 60) + 'px';
                wordPopup.classList.remove('hidden');
            }

            window.addEventListener('resize', () => {
                wordPopup.classList.add('hidden');
            });

            exploreCanvas.addEventListener('click', handleCanvasClick);
            popupSpeaker.addEventListener('click', (e) => {
                e.stopPropagation();
                speakWord(popupWord.textContent);
            });

            // ==================== 渲染学习模式 ====================
            function renderLearnMode() {
                cardsGrid.classList.remove('hidden');
                quizOptionsDiv.classList.add('hidden');
                exploreArea.classList.add('hidden');
                quizOptionsDiv.innerHTML = '';
                const scene = getCurrentScene();
                cardsGrid.innerHTML = '';

                scene.words.forEach((word) => {
                    const card = document.createElement('div');
                    card.className = 'word-card';
                    card.innerHTML = `
                        <div class="pixel-icon-wrap">
                            <canvas class="pixel-canvas" width="32" height="32"></canvas>
                            <span class="speaker-hint">🔊</span>
                        </div>
                        <span class="word-label">${word.en}</span>
                    `;
                    const canvas = card.querySelector('canvas');
                    drawPixelIcon(canvas, word.iconType, word.iconColor);
                    card.addEventListener('click', () => {
                        if (card.classList.contains('disabled-card')) return;
                        speakWord(word.en);
                        card.style.transition = 'transform 0.15s steps(3)';
                        card.style.transform = 'scale(1.08)';
                        setTimeout(() => { card.style.transform = ''; }, 150);
                        spawnStar(card);
                    });
                    cardsGrid.appendChild(card);
                });
            }

            // ==================== 渲染测验模式 ====================
            function renderQuizMode() {
                cardsGrid.classList.remove('hidden');
                quizOptionsDiv.classList.remove('hidden');
                exploreArea.classList.add('hidden');
                const scene = getCurrentScene();
                cardsGrid.innerHTML = '';
                quizOptionsDiv.innerHTML = '';
                isQuizLocked = false;

                const randomIndex = Math.floor(Math.random() * scene.words.length);
                quizTarget = scene.words[randomIndex];

                const options = new Set();
                options.add(quizTarget.en);
                const otherWords = scene.words.filter(w => w.en !== quizTarget.en);
                const shuffledOthers = [...otherWords].sort(() => Math.random() - 0.5);
                for (let i = 0; i < Math.min(3, shuffledOthers.length); i++) {
                    options.add(shuffledOthers[i].en);
                }
                if (options.size < 4) {
                    const allOtherWords = scenes
                        .flatMap(s => s.words)
                        .filter(w => !options.has(w.en) && w.en !== quizTarget.en);
                    const extraShuffled = [...allOtherWords].sort(() => Math.random() - 0.5);
                    for (const w of extraShuffled) {
                        if (options.size >= 4) break;
                        options.add(w.en);
                    }
                }
                quizOptionsList = [...options].sort(() => Math.random() - 0.5);

                const card = document.createElement('div');
                card.className = 'word-card';
                card.id = 'quizTargetCard';
                card.innerHTML = `
                    <div class="pixel-icon-wrap">
                        <canvas class="pixel-canvas" width="32" height="32"></canvas>
                    </div>
                    <span class="word-label" style="background:#ffe8ec;border-color:#f0b0b8;">❓ 这是什么？</span>
                `;
                const canvas = card.querySelector('canvas');
                drawPixelIcon(canvas, quizTarget.iconType, quizTarget.iconColor);
                card.addEventListener('click', () => {
                    if (!isQuizLocked) speakWord(quizTarget.en);
                });
                cardsGrid.appendChild(card);

                quizOptionsList.forEach(optionWord => {
                    const btn = document.createElement('button');
                    btn.className = 'quiz-option-btn';
                    btn.textContent = optionWord;
                    btn.addEventListener('click', () => {
                        if (isQuizLocked) return;
                        isQuizLocked = true;
                        handleQuizAnswer(optionWord, btn);
                    });
                    quizOptionsDiv.appendChild(btn);
                });
            }

            function handleQuizAnswer(selectedWord, clickedBtn) {
                const isCorrect = selectedWord === quizTarget.en;
                const allOptionBtns = quizOptionsDiv.querySelectorAll('.quiz-option-btn');
                const targetCard = document.getElementById('quizTargetCard');

                allOptionBtns.forEach(btn => {
                    btn.style.pointerEvents = 'none';
                    if (btn.textContent === quizTarget.en) {
                        btn.classList.add('correct-pick');
                    }
                });

                if (isCorrect) {
                    clickedBtn.classList.add('correct-pick');
                    if (targetCard) {
                        targetCard.classList.add('correct-flash');
                        targetCard.querySelector('.word-label').textContent = '✅ ' + quizTarget.en;
                        targetCard.querySelector('.word-label').style.background = '#e8f8e0';
                        targetCard.querySelector('.word-label').style.borderColor = '#5cb85c';
                    }
                    speakWord(quizTarget.en);
                    addScore();
                    showToast('🎉 正确！太厉害了！⭐');
                    spawnStar(clickedBtn);
                } else {
                    clickedBtn.classList.add('wrong-pick');
                    if (targetCard) {
                        targetCard.classList.add('wrong-flash');
                        targetCard.querySelector('.word-label').textContent = '❌ ' + quizTarget.en;
                        targetCard.querySelector('.word-label').style.background = '#ffe8ec';
                        targetCard.querySelector('.word-label').style.borderColor = '#e8536c';
                    }
                    speakWord(quizTarget.en);
                    showToast('😊 再试试看！正确答案是 ' + quizTarget.en);
                }

                setTimeout(() => {
                    if (currentMode === 'quiz') renderQuizMode();
                }, 2000);
            }

            // ==================== 发音功能 ====================
            function speakWord(word) {
                if (!('speechSynthesis' in window)) return;
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(word);
                utterance.lang = 'en-US';
                utterance.rate = 0.75;
                utterance.pitch = 1.1;
                const voices = window.speechSynthesis.getVoices();
                const englishVoice = voices.find(v => v.lang.startsWith('en') && v.name.includes('Female')) ||
                    voices.find(v => v.lang.startsWith('en')) || voices[0];
                if (englishVoice) utterance.voice = englishVoice;
                window.speechSynthesis.speak(utterance);
            }

            if ('speechSynthesis' in window) {
                window.speechSynthesis.getVoices();
                window.speechSynthesis.onvoiceschanged = () => {
                    window.speechSynthesis.getVoices();
                };
            }

            // ==================== 小星星特效 ====================
            function spawnStar(element) {
                const rect = element.getBoundingClientRect();
                const star = document.createElement('span');
                star.className = 'star-badge';
                star.textContent = '⭐';
                star.style.position = 'fixed';
                star.style.left = rect.left + rect.width / 2 - 14 + 'px';
                star.style.top = rect.top - 10 + 'px';
                star.style.zIndex = '200';
                star.style.pointerEvents = 'none';
                star.style.fontSize = '24px';
                document.body.appendChild(star);
                setTimeout(() => {
                    star.style.transition = 'all 0.8s ease-out';
                    star.style.transform = 'translateY(-60px) scale(0.3)';
                    star.style.opacity = '0';
                }, 50);
                setTimeout(() => {
                    if (star.parentNode) star.remove();
                }, 900);
            }

            // ==================== 全局渲染 ====================
            function renderSceneNav() {
                sceneNav.innerHTML = '';
                scenes.forEach(scene => {
                    const tab = document.createElement('button');
                    tab.className = 'scene-tab';
                    if (scene.id === currentSceneId) tab.classList.add('active');
                    tab.innerHTML = `<span class="tab-emoji">${scene.emoji}</span>${scene.name}`;
                    tab.addEventListener('click', () => {
                        currentSceneId = scene.id;
                        quizTarget = null;
                        quizOptionsList = [];
                        isQuizLocked = false;
                        renderAll();
                    });
                    sceneNav.appendChild(tab);
                });
            }

            function renderAll() {
                renderSceneNav();
                if (currentMode === 'learn') {
                    cardsGrid.classList.remove('hidden');
                    quizOptionsDiv.classList.add('hidden');
                    exploreArea.classList.add('hidden');
                    renderLearnMode();
                } else if (currentMode === 'quiz') {
                    cardsGrid.classList.remove('hidden');
                    quizOptionsDiv.classList.remove('hidden');
                    exploreArea.classList.add('hidden');
                    renderQuizMode();
                } else if (currentMode === 'explore') {
                    cardsGrid.classList.add('hidden');
                    quizOptionsDiv.classList.add('hidden');
                    exploreArea.classList.remove('hidden');
                    drawExploreScene();
                }
                updateScoreDisplay();
            }

            // ==================== 事件监听 ====================
            btnLearn.addEventListener('click', () => {
                currentMode = 'learn';
                btnLearn.classList.add('active');
                btnQuiz.classList.remove('active');
                btnExplore.classList.remove('active');
                quizTarget = null;
                renderAll();
                showToast('📖 学习模式：点击卡片听发音！');
            });

            btnQuiz.addEventListener('click', () => {
                currentMode = 'quiz';
                btnQuiz.classList.add('active');
                btnLearn.classList.remove('active');
                btnExplore.classList.remove('active');
                quizTarget = null;
                renderAll();
                showToast('🎮 测验模式：看图选单词！');
            });

            btnExplore.addEventListener('click', () => {
                currentMode = 'explore';
                btnExplore.classList.add('active');
                btnLearn.classList.remove('active');
                btnQuiz.classList.remove('active');
                quizTarget = null;
                renderAll();
                showToast('🔍 场景探索：点击物品学单词！');
            });

            btnReset.addEventListener('click', () => {
                resetScore();
                quizTarget = null;
                quizOptionsList = [];
                isQuizLocked = false;
                if (currentMode === 'quiz') renderQuizMode();
                if (currentMode === 'explore') drawExploreScene();
            });

            document.addEventListener('keydown', (e) => {
                const sceneKeys = ['1', '2', '3', '4', '5'];
                const idx = sceneKeys.indexOf(e.key);
                if (idx >= 0 && idx < scenes.length && !e.ctrlKey && !e.metaKey && !e.altKey) {
                    currentSceneId = scenes[idx].id;
                    quizTarget = null;
                    quizOptionsList = [];
                    isQuizLocked = false;
                    renderAll();
                }
                if (e.key === 'l' && !e.ctrlKey && !e.metaKey) btnLearn.click();
                if (e.key === 'q' && !e.ctrlKey && !e.metaKey) btnQuiz.click();
                if (e.key === 'e' && !e.ctrlKey && !e.metaKey) btnExplore.click();
            });

            // ==================== 初始化 ====================
            function init() {
                renderAll();
                updateScoreDisplay();
                setTimeout(() => {
                    showToast('👋 欢迎！点击物品听单词 🔊');
                }, 600);
            }

            init();
            console.log('🎨 像素单词乐园（探索版）已就绪！');
        })();
    </script>
</body>
</html>
